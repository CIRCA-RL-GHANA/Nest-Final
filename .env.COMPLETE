# ═══════════════════════════════════════════════════════════════════════════════
# PROMPT Genie Backend — COMPLETE Deployment Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Replace every placeholder value before going live.
# Generate secrets: openssl rand -hex 32
# NEVER commit this file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─ APPLICATION ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_PREFIX=api
API_VERSION=v1
APP_NAME=PROMPT Genie
APP_DESCRIPTION=Complete Full-Stack Application
APP_VERSION=1.0.0
TZ=UTC
APP_URL=https://api.genieinprompt.app

# Domain names used by nginx
API_DOMAIN=api.genieinprompt.app
FRONTEND_DOMAIN=genieinprompt.app

# ─ DATABASE (PostgreSQL 15) ────────────────────────────────────────────────────
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_strong_db_password_min_32_chars
DB_NAME=promptgenie_prod
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000
DB_MIGRATIONS_RUN=true
DB_MIGRATIONS_DIR=src/database/migrations

# ─ REDIS CACHE (Redis 7) ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_min_32_chars
REDIS_DB=0
REDIS_TTL=86400
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400
REDIS_POOL_SIZE=10
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100

# ─ JWT AUTHENTICATION ────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_random_secret_min_64_chars_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_random_refresh_secret_min_64_chars_generate_with_openssl_rand_base64_64
JWT_REFRESH_EXPIRES_IN=30d

# ─ SESSION ────────────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_random_session_secret_min_32_chars
SESSION_TIMEOUT=3600000

# ─ ENCRYPTION & SECURITY ──────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
PIN_ENCRYPTION_KEY=CHANGE_ME_32_char_hex_key_openssl_rand_hex_16
PIN_ENCRYPTION_IV=CHANGE_ME_16_char_iv_openssl_rand_hex_8
PIN_ALGORITHM=aes-256-cbc

# ─ CORS & SECURITY ────────────────────────────────────────────────────────────
CORS_ORIGIN=https://genieinprompt.app,https://www.genieinprompt.app
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization
FORCE_HTTPS=true
TRUST_PROXY=true
HTTPS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
CSP_ENABLED=true
CSP_DEFAULT_SRC=self
CSP_SCRIPT_SRC=self
CSP_STYLE_SRC=self
CSP_IMG_SRC=self
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# ─ EMAIL (SendGrid) ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.CHANGE_ME_your_sendgrid_api_key_here
EMAIL_FROM=noreply@genieinprompt.app
EMAIL_FROM_NAME=PROMPT Genie
EMAIL_SUPPORT=support@genieinprompt.app
EMAIL_REPLY_TO=reply@genieinprompt.app
EMAIL_VERIFICATION_ENABLED=true
EMAIL_WELCOME_TEMPLATE_ID=CHANGE_ME_sendgrid_template_id
EMAIL_FORGOT_PASSWORD_TEMPLATE_ID=CHANGE_ME_sendgrid_template_id
EMAIL_ORDER_CONFIRMATION_TEMPLATE_ID=CHANGE_ME_sendgrid_template_id

# ─ SMS/OTP (Twilio) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME_ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=CHANGE_ME_your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
SMS_ENABLED=true
SMS_PROVIDER=twilio
SMS_RATE_LIMIT=3
SMS_RATE_LIMIT_WINDOW=3600

# ─ FILE UPLOAD & STORAGE ──────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DESTINATION=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,ppt,pptx,zip
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
STORAGE_PROVIDER=local

# ─ AWS S3 (For production file storage) ───────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME_your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=CHANGE_ME_your_aws_secret_access_key
AWS_S3_BUCKET=promptgenie-uploads-prod
AWS_S3_URL=https://promptgenie-uploads-prod.s3.amazonaws.com
AWS_CLOUDFRONT_URL=

# ─ GOOGLE MAPS ────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=CHANGE_ME_your_google_maps_api_key
GOOGLE_MAPS_ENABLED=false
MAX_RIDE_SEARCH_RADIUS_KM=50

# ─ AI/ML FEATURES ──────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_PROVIDER=openai
AI_MODEL_PATH=./ml-models
ML_MODEL_PATH=./ml-models
ML_ENABLED=false
TENSORFLOW_ENABLED=false

# OpenAI-compatible inference API
AI_API_KEY=CHANGE_ME_sk_your_openai_or_compatible_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_TOP_P=0.9
AI_REQUEST_TIMEOUT=30000

# NLP
AI_NLP_LANGUAGE=English
AI_TFIDF_MAX_DOCUMENTS=10000

# Dynamic Pricing
AI_SURGE_MAX_MULTIPLIER=3.5
AI_SURGE_PEAK_HOURS=7-9,17-20
AI_PLATFORM_FEE_PCT=8

# Fraud Detection
AI_FRAUD_BLOCK_THRESHOLD=0.85
AI_FRAUD_REVIEW_THRESHOLD=0.55
AI_FRAUD_LOCATION_THRESHOLD_KM=500

# Financial Insights
AI_FORECAST_HORIZON_DAYS=30
AI_SAVINGS_RATE_ALERT_PCT=20

# Collaborative Filtering
AI_COLLAB_FILTER_TOP_N=5

# Feature store update interval (ms)
FEATURE_STORE_UPDATE_INTERVAL=300000

# ─ Q POINTS MARKET – AI LIQUIDITY MANAGER ────────────────────────────────────
AI_MARKET_ENABLED=false
AI_PARTICIPANT_USER_ID=00000000-0000-0000-0000-000000000001
AI_TARGET_INVENTORY=250000000000000
AI_MIN_INVENTORY=50000000000000
AI_MAX_INVENTORY=490000000000000
QPOINTS_TOTAL_SUPPLY=500000000000000
AI_TARGET_SPREAD_PCT=2.0
AI_ORDER_BASE_QTY=500
AI_MAX_ORDER_QTY=2500
AI_MAX_OPEN_ORDERS=10
AI_ORDER_TTL_SECONDS=300
AI_RUN_INTERVAL_SECONDS=30
AI_MIN_CASH_RESERVE_USD=5000

# ─ RATE LIMITING ──────────────────────────────────────────────────────────────
THROTTLE_ENABLED=true
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_RATE_LIMIT=5
AUTH_RATE_LIMIT_WINDOW=900000
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=3600000
FILE_UPLOAD_RATE_LIMIT=10

# ─ QUEUE & JOBS (Bull + Redis) ────────────────────────────────────────────────
QUEUE_ENABLED=true
QUEUE_REDIS_HOST=redis
QUEUE_REDIS_PORT=6379
QUEUE_CONCURRENCY=5
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF=5000
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=5000
QUEUE_CLEAN_COMPLETED=true
QUEUE_CLEAN_FAILED=false

# Job Processors
PROCESS_EMAILS=true
PROCESS_SMS=true
PROCESS_REPORTS=true
PROCESS_CLEANUP=true
PROCESS_SYNC=true

# ─ LOGGING (Winston) ──────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=30
LOG_FORMAT=json
LOG_CONSOLE=true
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ─ MONITORING & ERROR TRACKING ─────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=30000
METRICS_ENABLED=true
METRICS_PORT=9090
PROFILING_ENABLED=false
DB_HEALTH_CHECK_TIMEOUT=5000
DB_HEALTH_CHECK_INTERVAL=30000
REDIS_HEALTH_CHECK_TIMEOUT=5000
REDIS_HEALTH_CHECK_INTERVAL=30000

# Sentry error tracking
SENTRY_DSN=CHANGE_ME_https://your_sentry_dsn@sentry.io/your_project_id
SENTRY_ENABLED=true

# ─ SWAGGER / API DOCS ─────────────────────────────────────────────────────────
ENABLE_SWAGGER=true
SWAGGER_PATH=/api/docs
SWAGGER_TITLE=PROMPT Genie API
SWAGGER_DESCRIPTION=Complete API documentation
SWAGGER_VERSION=1.0.0

# ─ WEBSOCKET (Socket.IO) ──────────────────────────────────────────────────────
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3001
WEBSOCKET_NAMESPACE=/socket.io
WEBSOCKET_CORS_ORIGIN=https://genieinprompt.app
WEBSOCKET_HEARTBEAT_TIMEOUT=60000
WEBSOCKET_HEARTBEAT_INTERVAL=25000
SOCKETIO_ADAPTER=redis
SOCKETIO_REDIS_HOST=redis
SOCKETIO_REDIS_PORT=6379

# ─ PAYMENT FACILITATOR (Q Points Market Cash Settlement) ─────────────────────
# Set PROVIDER=paystack or flutterwave and supply live keys before going live.
PAYMENT_FACILITATOR_PROVIDER=mock
PAYMENT_FACILITATOR_SECRET_KEY=CHANGE_ME_sk_live_your_paystack_or_flutterwave_secret_key
PAYMENT_FACILITATOR_PUBLIC_KEY=CHANGE_ME_pk_live_your_paystack_or_flutterwave_public_key
PAYMENT_FACILITATOR_WEBHOOK_SECRET=CHANGE_ME_whsec_your_webhook_secret_min_32_chars
PAYMENT_FACILITATOR_WEBHOOK_URL=https://api.genieinprompt.app/api/v1/qpoints/webhooks/payment
PAYMENT_FACILITATOR_CURRENCY=NGN

# Stripe (optional, if used alongside facilitator)
STRIPE_PUBLIC_KEY=CHANGE_ME_pk_live_your_stripe_public_key
STRIPE_SECRET_KEY=CHANGE_ME_sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=CHANGE_ME_whsec_your_stripe_webhook_secret

# ─ EXTERNAL SERVICES ─────────────────────────────────────────────────────────
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=mixpanel
MIXPANEL_TOKEN=CHANGE_ME_your_mixpanel_token

# ─ DATABASE BACKUP & MAINTENANCE ─────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE=s3
BACKUP_S3_BUCKET=promptgenie-backups
BACKUP_ENCRYPTION=true
MAINTENANCE_ENABLED=false
MAINTENANCE_WINDOW=02:00-03:00
MAINTENANCE_MESSAGE=System maintenance in progress

# ─ PERFORMANCE ────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
QUERY_TIMEOUT=30000
QUERY_CACHE=true

# ─ COMPLIANCE & REGULATIONS ───────────────────────────────────────────────────
GDPR_ENABLED=true
DATA_RETENTION_DAYS=1095
DELETE_INACTIVE_AFTER_DAYS=730
TERMS_VERSION=1.0.0
PRIVACY_VERSION=1.0.0
COOKIE_CONSENT_REQUIRED=true

# ─ FEATURE FLAGS ─────────────────────────────────────────────────────────────
FEATURE_BIOMETRIC_AUTH=true
FEATURE_PIN_PROTECTION=true
FEATURE_OFFLINE_MODE=true
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_REAL_TIME_CHAT=true
FEATURE_RIDE_HAILING=true
FEATURE_FINANCIAL_OPERATIONS=true
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_SOCIAL_LOGIN=false
FEATURE_MARKETPLACE=true
FEATURE_PAYMENTS=true
FEATURE_WALLET=true
FEATURE_FILE_UPLOAD=true
FEATURE_NOTIFICATIONS=true
FEATURE_LIVE_STREAMING=false

# ─ DEPLOYMENT ────────────────────────────────────────────────────────────────
DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_REPLICAS=1
DEPLOYMENT_RESTART_POLICY=unless-stopped
DOCKER_IMAGE_TAG=latest
DOCKER_REGISTRY=CHANGE_ME_your_registry_url
DOCKER_USERNAME=CHANGE_ME_your_docker_username
DOCKER_PASSWORD=CHANGE_ME_your_docker_password

# ═══════════════════════════════════════════════════════════════════════════════
# BEFORE GOING LIVE — update every value marked CHANGE_ME
# Generate secrets: openssl rand -hex 32   (or -base64 64 for JWT)
# Validate config: npm run validate:env
# ═══════════════════════════════════════════════════════════════════════════════
